  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#786F82",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#E6D7A8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": {
        "foreground": "#B06ED1"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#C4A45A",
        "fontStyle": ""
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#8FBEC6"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class", "entity.name.struct"],
      "settings": {
        "foreground": "#B9A1E8"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "entity.name.variable"],
      "settings": {
        "foreground": "#E8E1D2"
      }
    },
    {
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#D8D0C0"
      }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": {
        "foreground": "#D33A52"
      }
    },
    {
      "scope": ["entity.other.attribute-name", "support.type.property-name", "meta.object-literal.key"],
      "settings": {
        "foreground": "#C4A45A"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#A49AAD"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#F1E8D2",
        "background": "#9E102B"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B9A1E8",
    "class": "#B9A1E8",
    "struct": "#B9A1E8",
    "interface": "#B9A1E8",
    "enum": "#B9A1E8",
    "function": "#8FBEC6",
    "method": "#8FBEC6",
    "property": "#C4A45A",
    "variable.readonly": "#E6D7A8",
    "parameter": "#D8D0C0",
    "typeParameter": "#B06ED1",
    "keyword": "#C4A45A",
    "string": "#E6D7A8",
    "number": "#B06ED1",
    "regexp": "#6E8B6F",
    "operator": "#A49AAD"
  }
}
